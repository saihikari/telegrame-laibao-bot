# Telegram Bot Token
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Webhook or Polling mode (Set WEBHOOK_URL if using webhook)
# WEBHOOK_URL=https://ql.runtoads.top

# Domain for WebApp
WEBDOMAIN=https://ql.runtoads.top

# Admin IDs (comma separated)
ADMIN_TG_IDS=8413696128,7746892135

# QL API Credentials
QL_USERNAME=your_username
QL_PASSWORD=your_password

# Optional Ports
# PORT=8091

# Random Delay Between Records (seconds)
DELAY_MIN_SECONDS=6
DELAY_MAX_SECONDS=12

# Operator Suffix Mapping (Format: TG_ID=SUFFIX,TG_ID=SUFFIX)
# e.g., OPERATOR_SUFFIX_MAP=12345678=-XX,12345679=-ST
OPERATOR_SUFFIX_MAP=
